{
  "MongoDbSettings": {
    "ConnectionString": "${MONGODB_CONNECTION_STRING:-mongodb://admin:admin123@localhost:27017}",
    "DatabaseName": "${MONGODB_DATABASE:-RepairFlow}"
  },
  "JwtSettings": {
    "SecretKey": "${JWT_SECRET_KEY:-CHANGE_ME_IN_PRODUCTION_MIN_32}",
    "Issuer": "RepairFlow.API",
    "Audience": "RepairFlow.Client",
    "ExpirationHours": 8
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}
